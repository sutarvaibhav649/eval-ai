# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# Redis — Celery broker
REDIS_URL=redis://localhost:6379/0

# Java callback URL
JAVA_BASE_URL=http://localhost:8081

# OCR mode — PADDLE for local dev, GEMINI for prod
OCR_MODE=PADDLE

# Gemini API key — only needed when OCR_MODE=GEMINI
GEMINI_API_KEY=your-gemini-api-key-here

# Upload base path — must match Java's upload path
UPLOAD_BASE_PATH=../upload

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2